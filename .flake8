[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    instance,
    venv,
    .venv,
    migrations,
    *.pyc,
    # Same rationale as the [tool.black].exclude block in pyproject.toml.
    skills/superpowers,
    .kilo,
    locustfile.py,
    run_performance_test.py,
    test_mcp_client.py,
    test_linear_mcp.py
extend-ignore =
    E203,
    W503,
    E402,
    E711,
    E712,
    E741,
    F401,
    F541,
    F811,
    F821,
    F841
