#!/usr/bin/env python3
"""
Test script to verify Cursor IDE rule adaptations maintain compatibility
with the core AI_POLICY.md rules.
"""

import json
import os
import re
from pathlib import Path


def test_cursor_rules_integrity():
    """Test that Cursor rules don't break core policy."""

    print("=" * 70)
    print("Testing Cursor Rules Integrity")
    print("=" * 70)

    # Test 1: Core policy file exists
    print("\n[Test 1] Checking AI_POLICY.md exists...")
    core_policy = Path("AI_POLICY.md")
    assert core_policy.exists(), "AI_POLICY.md must exist"
    print("✓ AI_POLICY.md exists")

    # Test 2: Cursor rules file exists
    print("\n[Test 2] Checking AI_POLICY_CURSOR.md exists...")
    cursor_policy = Path("AI_POLICY_CURSOR.md")
    assert cursor_policy.exists(), "AI_POLICY_CURSOR.md must exist"
    print("✓ AI_POLICY_CURSOR.md exists")

    # Test 3: No duplication of core rules
    print("\n[Test 3] Checking for rule duplication...")
    with open(core_policy, 'r') as f:
        core_content = f.read()
    with open(cursor_policy, 'r') as f:
        cursor_content = f.read()

    # Check that core policy concepts are referenced, not duplicated
    assert "single source of truth" in cursor_content.lower()
    assert "AI_POLICY.md" in cursor_content
    print("✓ No rule duplication detected")

    # Test 4: Cursor-specific adaptations exist
    print("\n[Test 4] Checking Cursor-specific adaptations...")
    cursor_adapters_path = Path(".qwen/agents/cursor_adapters.md")
    assert cursor_adapters_path.exists(), "Cursor adapters must exist"
    print("✓ Cursor adapters file exists")

    # Test 5: .cursorrules exists
    print("\n[Test 5] Checking .cursorrules exists...")
    cursor_rules = Path(".cursorrules")
    assert cursor_rules.exists(), ".cursorrules must exist"
    print("✓ .cursorrules exists")

    # Test 6: Verify workflow consistency
    print("\n[Test 6] Checking workflow consistency...")
    workflow_pattern = r"ANALYST → ARCHITECT → PLANNER → DEVELOPER → QA_TESTER → CODE_REVIEWER → @save"
    with open(cursor_rules, 'r') as f:
        cursor_rules_content = f.read()
    assert re.search(workflow_pattern, cursor_rules_content), "Workflow must be consistent"
    print("✓ Workflow is consistent with core policy")

    # Test 7: Check safety rules
    print("\n[Test 7] Checking safety rules...")
    safety_checks = [
        "NO silent breaking changes",
        "NO unrelated modifications",
        "PREFER minimal reversible changes",
        "REQUIRE .env for secrets"
    ]
    with open(cursor_rules, 'r') as f:
        rules_content = f.read()
    for check in safety_checks:
        assert check in rules_content, f"Safety rule '{check}' must be present"
    print("✓ All safety rules present")

    # Test 8: Verify agent mappings
    print("\n[Test 8] Checking agent mappings...")
    agent_patterns = {
        "Research Agent": ["ANALYST", "ARCHITECT", "PLANNER", "DESIGNER"],
        "Code Agent": ["DEVELOPER", "QA_TESTER", "CODE_REVIEWER"]
    }
    with open("AI_POLICY_CURSOR.md", 'r') as f:
        cursor_policy_content = f.read()
    for agent_type, roles in agent_patterns.items():
        for role in roles:
            assert role in cursor_policy_content, f"Role {role} must be mapped"
    print("✓ All agent mappings present")

    # Test 9: Check .qwen/config.json
    print("\n[Test 9] Checking .qwen/config.json...")
    config_path = Path(".qwen/config.json")
    assert config_path.exists(), ".qwen/config.json must exist"
    with open(config_path, 'r') as f:
        config = json.load(f)
    assert "hybrid" in config.get("operation_mode", {}).get("current", ""), "Must be in hybrid mode"
    print("✓ Configuration is correct")

    # Test 10: Verify project state
    print("\n[Test 10] Checking project state...")
    state_path = Path(".qwen/context/state_summary.md")
    assert state_path.exists(), "State summary must exist"
    with open(state_path, 'r') as f:
        state_content = f.read()
    assert "Stage 12" in state_content, "Must be at stage 12"
    assert "✅" in state_content, "Stage must be completed"
    print("✓ Project state is correct")

    # Test 11: Check for cross-IDE compatibility notes
    print("\n[Test 11] Checking cross-IDE compatibility...")
    compat_keywords = ["cross-IDE", "compatible", "portable", "other IDEs"]
    with open("AI_POLICY_CURSOR.md", 'r') as f:
        compat_content = f.read()
    for keyword in compat_keywords:
        assert keyword.lower() in compat_content.lower(), f"Must mention {keyword}"
    print("✓ Cross-IDE compatibility documented")

    # Test 12: Verify delegation protocol
    print("\n[Test 12] Checking delegation protocol...")
    delegation_keywords = ["@delegate", "Delegation", "Research Agent", "Code Agent"]
    with open("AI_POLICY_CURSOR.md", 'r') as f:
        delegation_content = f.read()
    for keyword in delegation_keywords:
        assert keyword in delegation_content, f"Must mention {keyword}"
    print("✓ Delegation protocol documented")

    print("\n" + "=" * 70)
    print("All tests passed! ✓")
    print("=" * 70)
    print("\nSummary:")
    print("- Core policy preserved")
    print("- Cursor adaptations implemented")
    print("- Safety rules enforced")
    print("- Cross-IDE compatibility maintained")
    print("- All configurations correct")


if __name__ == "__main__":
    test_cursor_rules_integrity()