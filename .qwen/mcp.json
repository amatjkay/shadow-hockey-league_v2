{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "c:\\dev\\shadow\\shadow-hockey-league_v2"
      ],
      "description": "Доступ к файлам проекта (14 инструментов) — ОСНОВНОЙ"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "description": "Анализ задач (1 инструмент) — ОСНОВНОЙ"
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch",
        "--user-agent",
        "Shadow-Hockey-League-MCP/1.0"
      ],
      "description": "HTTP запросы (1 инструмент) — ОСНОВНОЙ"
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub API (40 инструментов) — ВКЛЮЧАТЬ ПО ТРЕБОВАНИЮ",
      "disabled": true
    }
  }
}
