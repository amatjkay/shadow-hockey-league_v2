{
  "system_identity": {
    "name": "MasterRouter_v2.3_Turnkey",
    "version": "2.3.1"
  },
  "llm_provider": {
    "current": "qwen_code_companion",
    "supported": ["qwen_code_companion", "openai_gpt4", "google_gemini", "anthropic_claude", "dashscope_api", "ollama_local"],
    "note": "API ключи НЕ используются. Интеграция через плагин или промпты."
  },
  "operation_mode": {
    "current": "hybrid",
    "modes": {
      "full_subagents": "Только Qwen Code Companion",
      "hybrid": "Автоопределение возможностей",
      "direct_only": "Все LLM как универсальные эксперты"
    }
  },
"smart_routing": {
  "enabled": true,
  "auto_save": true,
  "enforce_checkpoint": true,
  "interruption_policy": {
    "intermediate_confirmation": false,
    "final_acceptance_required": true,
    "approve_command": "@approve",
    "reject_command": "@reject"
  }
},
  "workflow_chain": {
    "default_sequence": ["ANALYST", "ARCHITECT", "PLANNER", "DEVELOPER", "QA_TESTER", "CODE_REVIEWER", "@save"],
    "smart_routing_rules": {
      "skip_qa_conditions": [
        "Исправление критического бага (hotfix)",
        "Рефакторинг без изменения логики",
        "Документация, стили, конфиги",
        "Явный запрос пользователя: '@skip_qa'"
      ],
      "fallback_if_qa_skipped": ["DEVELOPER", "CODE_REVIEWER", "@save"],
      "reviewer_scope": "Проверяет код И тесты (если есть). Если тесты отсутствуют в фиче → блокирует @save до их добавления."
    },
    "delegation_logic": {
      "reviewer_rejects_code": "@delegate DEVELOPER Fix logic/security",
      "reviewer_rejects_tests": "@delegate QA_TESTER Improve coverage/isolation",
      "reviewer_approves": "@save + подтверждение готовности к интеграции"
    }
  },
  "context": {
    "paths": {
      "state": ".qwen/context/state_summary.md",
      "plan": ".qwen/context/active_plan.md",
      "memory": ".qwen/context/memory.md"
    },
    "max_tokens_before_summary": 100000
  },
  "roles": {
    "active": ["ANALYST", "ARCHITECT", "PLANNER", "DEVELOPER", "QA_TESTER", "DESIGNER", "CODE_REVIEWER"],
    "auto_triggers": {
      "ANALYST": ["требования", "бизнес-логика", "что нужно сделать", "анализ", "спецификация"],
      "ARCHITECT": ["архитектура", "структура", "паттерны", "спроектируй", "схема", "ADR"],
      "PLANNER": ["план", "задачи", "декомпозиция", "оценка", "спринт", "приоритет"],
      "DEVELOPER": ["напиши код", "реализуй", "функция", "исправь", "рефакторинг", "баг", "ошибка"],
      "QA_TESTER": ["тесты", "проверь", "qa", "покрытие", "автотесты", "баг-репорт"],
      "DESIGNER": ["дизайн", "ui", "ux", "макет", "интерфейс", "визуал"],
      "CODE_REVIEWER": ["ревью", "аудит", "безопасность", "финальная проверка", "качество кода"]
    }
  }
}