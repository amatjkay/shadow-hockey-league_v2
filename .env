# Shadow Hockey League Environment Configuration
# Development environment

# Режим работы приложения
FLASK_ENV=development

# URL базы данных (АБСОЛЮТНЫЙ путь)
# DATABASE_URL=sqlite:///c:/dev/shadow/shadow-hockey-league_v2/dev.db

# Секретный ключ для сессий (dev-режим)
SECRET_KEY=dev-secret-key-change-in-production

# CSRF secret key
WTF_CSRF_SECRET_KEY=csrf-dev-key-change-in-production

# Уровень логирования
LOG_LEVEL=INFO

# Порт и хост сервера
FLASK_RUN_PORT=5000
FLASK_RUN_HOST=127.0.0.1

# API (включено для локальной разработки)
ENABLE_API=True
API_KEY_SECRET=dev-api-key-secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Gemini API Key
GEMINI_API_KEY=AIzaSyABTjRbtQH2s6gB9UCzNu7iWOE8EMwoFaQ