# Shadow Hockey League Environment Variables

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# Database
# IMPORTANT: Use absolute path to prevent instance/ folder issues
DATABASE_URL=sqlite:///C:/dev/shadow/shadow-hockey-league_v2/dev.db

# Logging
LOG_LEVEL=INFO

# API Configuration
ENABLE_API=true

# Redis (Этап 1: Кэширование)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# GitHub (для MCP сервера)
# GITHUB_TOKEN=ghp_your_token_here
