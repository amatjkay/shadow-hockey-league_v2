# Shadow Hockey League v2 — Environment Configuration
# Скопируйте этот файл в .env и настройте значения
#
# Для production: cp .env.example .env
# Для development: скопируйте и измените FLASK_ENV=development

# ==========================================
# Основные настройки
# ==========================================

# Режим работы приложения (development/production/testing)
FLASK_ENV=development

# URL базы данных
# ⚠️ ВАЖНО: Используйте АБСОЛЮТНЫЙ путь для SQLite!
#
# Примеры:
#   Windows:  sqlite:///C:/path/to/shadow-hockey-league_v2/dev.db
#   Linux:    sqlite:////home/user/projects/shadow-hockey-league_v2/dev.db
#   VPS:      sqlite:////home/shleague/shadow-hockey-league_v2/instance/dev.db
#   PostgreSQL: postgresql://user:password@localhost/dbname
# По умолчанию (если переменная не задана) config.py использует абсолютный
# путь к ./dev.db в корне проекта — отдельно прописывать DATABASE_URL не нужно.
# DATABASE_URL=sqlite:////absolute/path/to/dev.db

# Секретный ключ для сессий
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ Никогда не используйте значение по умолчанию в production!
SECRET_KEY=your-secret-key-change-in-production

# Уровень логирования (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Порт и хост сервера (опционально)
FLASK_RUN_PORT=5000
FLASK_RUN_HOST=127.0.0.1

# ==========================================
# Redis (кэширование)
# ==========================================
# Запуск: docker run -d --name shadow-redis -p 6379:6379 redis:7-alpine
# Или: redis.bat start (Windows) / ./redis.sh start (Linux)

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ==========================================
# API настройки
# ==========================================

# Включение REST API (True/False)
# В production рекомендуется True с использованием API Keys
ENABLE_API=True

# Секрет для генерации API ключей
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ Обязательно измените в production!
API_KEY_SECRET=your-api-key-secret-change-in-production

# ==========================================
# CSRF защита админ-панели
# ==========================================

# Секретный ключ для CSRF токенов (Flask-WTF)
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ Обязательно измените в production!
WTF_CSRF_SECRET_KEY=your-csrf-secret-key-change-in-production

# ==========================================
# Опционально
# ==========================================

# GitHub токен (для MCP Server и интеграций)
# Создать: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# ==========================================
# Опциональные ключи внешних AI/MCP сервисов
# ==========================================

# Gemini API (опционально, для локальных AI-инструментов).
# Получить: https://aistudio.google.com/app/apikey
# Хранить только в .env (никогда не коммитить).
# GEMINI_API_KEY=
