# Shadow Hockey League Environment Configuration
# Скопируйте этот файл в .env и настройте значения

# Режим работы приложения (development/production/testing)
FLASK_ENV=development

# URL базы данных
# ⚠️ ВАЖНО: Используйте АБСОЛЮТНЫЙ путь для предотвращения проблемы с папкой instance/!
#
# Для Windows (локально):
# DATABASE_URL=sqlite:///C:/dev/shadow/shadow-hockey-league_v2/dev.db
#
# Для Linux/Mac (локально):
# DATABASE_URL=sqlite:////home/user/projects/shadow-hockey-league_v2/dev.db
#
# Для PythonAnywhere:
# DATABASE_URL=sqlite:////home/amatjkay/shadow-hockey-league_v2/dev.db
#
# Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///C:/dev/shadow/shadow-hockey-league_v2/dev.db

# Секретный ключ для сессий (должен быть уникальным для production!)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ Никогда не используйте значение по умолчанию в production!
SECRET_KEY=your-secret-key-change-in-production

# Уровень логирования (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Порт сервера (опционально, по умолчанию 5000)
FLASK_RUN_PORT=5000

# Хост сервера (опционально, по умолчанию 127.0.0.1)
FLASK_RUN_HOST=127.0.0.1

# ==========================================
# Redis (Этап 1: Кэширование)
# ==========================================
# Redis подключается через Docker: redis://localhost:6379/0
# Для запуска: docker run -d --name shadow-redis -p 6379:6379 redis:7-alpine
# Или используйте: redis.bat start (Windows) / ./redis.sh start (Linux)

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ==========================================
# GitHub MCP Server (опционально)
# ==========================================
# Создайте токен: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here
