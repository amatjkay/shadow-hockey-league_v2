# Shadow Hockey League Environment Configuration
# Скопируйте этот файл в .env и настройте значения

# Режим работы приложения (development/production/testing)
FLASK_ENV=development

# URL базы данных
# Для SQLite: sqlite:///dev.db
# Для PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///dev.db

# Секретный ключ для сессий (должен быть уникальным для production!)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# Уровень логирования (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Порт сервера (опционально, по умолчанию 5000)
FLASK_RUN_PORT=5000

# Хост сервера (опционально, по умолчанию 127.0.0.1)
FLASK_RUN_HOST=127.0.0.1
