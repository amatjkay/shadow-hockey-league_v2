# Shadow Hockey League Environment Configuration
# Скопируйте этот файл в .env и настройте значения

# Режим работы приложения (development/production/testing)
FLASK_ENV=development

# URL базы данных
# Для SQLite (локально): sqlite:///dev.db
# Для SQLite (PythonAnywhere): sqlite:////home/username/project/dev.db
# Для PostgreSQL: postgresql://user:password@localhost/dbname
#
# ⚠️ ВАЖНО: На сервере используйте АБСОЛЮТНЫЙ путь!
# Относительные пути (sqlite:///dev.db) работают только локально.
# На PythonAnywhere WSGI запускается из /var/www/, поэтому нужно:
# DATABASE_URL=sqlite:////home/amatjkay/shadow-hockey-league_v2/dev.db
DATABASE_URL=sqlite:///dev.db

# Секретный ключ для сессий (должен быть уникальным для production!)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ Никогда не используйте значение по умолчанию в production!
SECRET_KEY=your-secret-key-change-in-production

# Уровень логирования (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Порт сервера (опционально, по умолчанию 5000)
FLASK_RUN_PORT=5000

# Хост сервера (опционально, по умолчанию 127.0.0.1)
FLASK_RUN_HOST=127.0.0.1

# Токен для webhook деплоя (опционально, для CI/CD через webhook)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
# Используется только для Варианта 3 деплоя (Flask webhook)
DEPLOY_TOKEN=your-deploy-token-here
